@page "/"
@inject HttpClient Http

<PageTitle>Gear Maintenance</PageTitle>

<MudText Typo="@Typo.h4" GutterBottom="true">Your Gear Status</MudText>

@if (_loading)
{
    <MudProgressCircular Color="@Color.Primary" Indeterminate="true" />
}
else if (!_gears.Any())
{
    <MudAlert Severity="@Severity.Info" Class="mb-4">No gear found. Please ensure you have connected your Strava account in the settings and wait for the sync to complete (it runs every 5 minutes).</MudAlert>
    <MudButton Variant="@Variant.Filled" Color="@Color.Primary" Href="/settings">Go to Settings</MudButton>
}
else
{
    <MudTable Items="@_gears" Hover="true" Breakpoint="@Breakpoint.Sm" Loading="@_loading" LoadingProgressColor="@Color.Info">
        <HeaderContent>
            <MudTh>Name</MudTh>
            <MudTh>Distance (km)</MudTh>
            <MudTh>Status</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Name">@context.Name</MudTd>
            <MudTd DataLabel="Distance">@(Math.Round(context.TotalDistance / 1000.0, 2))</MudTd>
            <MudTd DataLabel="Maintenance Status">
                <MudChip T="string" Color="@GetStatusColor(context.Status)" Variant="Variant.Filled">@(GetStatusText(context.Status))</MudChip>
            </MudTd>
        </RowTemplate>
    </MudTable>
}

@code {
    private List<GearDto> _gears = new List<GearDto>();
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _gears = await Http.GetFromJsonAsync<List<GearDto>>("api/Gear") ?? new List<GearDto>();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error fetching gears: {ex.Message}");
            _gears = new List<GearDto>();
        }
        finally
        {
            _loading = false;
        }
    }

    private string GetStatusText(string? status)
    {
        if (string.IsNullOrEmpty(status)) return "Unknown";
        return status switch
        {
            "Healthy" => "Healthy",
            "ServiceRequired" => "Service Required",
            "Warning" => "Warning",
            "Critical" => "Critical",
            _ => status
        };
    }

    private Color GetStatusColor(string? status)
    {
        if (status == null) return Color.Default;
        return status.ToLower() switch
        {
            "healthy" => Color.Success,
            "servicerequired" => Color.Warning,
            "warning" => Color.Warning,
            "critical" => Color.Error,
            _ => Color.Default
        };
    }
}
