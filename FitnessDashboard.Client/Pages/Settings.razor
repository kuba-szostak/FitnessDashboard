@page "/settings"
@using FitnessDashboard.Domain.Entities
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject NavigationManager NavigationManager

<PageTitle>Strava Settings</PageTitle>

<MudText Typo="@Typo.h4" GutterBottom="true">Strava Connection</MudText>
@if (athletes == null || !athletes.Any())
{
    <MudPaper Class="pa-4 mt-4">
        <MudText Typo="@Typo.h6">Connect Your Account</MudText>
        <MudText Typo="@Typo.body2" Class="mb-4">To fetch your gear and activities correctly, please connect your Strava account using the button below. This will authorize the application to read your profile and activities.</MudText>
        
        <div class="d-flex align-center justify-center mb-6">
            <MudButton Variant="@Variant.Filled" Color="@Color.Primary" Size="@Size.Large" OnClick="LoginWithStrava" StartIcon="@Icons.Material.Filled.Login">
                Log in with Strava
            </MudButton>
        </div>
    </MudPaper>
}

@if (athletes != null && athletes.Any())
{
    <MudText Typo="@Typo.h6" Class="mt-8 mb-4">Connected Accounts</MudText>
    @foreach (var a in athletes)
    {
        <MudCard Class="mb-2">
            <MudCardContent>
                <div class="d-flex align-center">
                    @if (!string.IsNullOrEmpty(a.ProfileImageUrl))
                    {
                        <MudAvatar Image="@a.ProfileImageUrl" Class="mr-4" />
                    }
                    else
                    {
                        <MudAvatar Color="@Color.Info" Class="mr-4">@a.FirstName[0]</MudAvatar>
                    }
                    <div>
                        <MudText Typo="@Typo.h6">@a.FirstName @a.LastName</MudText>
                        <MudText Typo="@Typo.caption">ID: @a.Id</MudText>
                    </div>
                    <MudSpacer />
                    <MudButton Variant="@Variant.Outlined" Color="@Color.Error" StartIcon="@Icons.Material.Filled.Logout" OnClick="@(() => Logout(a.Id))">
                        Disconnect
                    </MudButton>
                </div>
            </MudCardContent>
        </MudCard>
    }
}

@code {
    private bool success;
    private MudForm form;
    private Athlete athlete = new Athlete();
    private List<AthleteDto>? athletes;

    protected override async Task OnInitializedAsync()
    {
        await LoadAthletes();
    }

    private async Task LoadAthletes()
    {
        try
        {
            athletes = await Http.GetFromJsonAsync<List<AthleteDto>>("api/Athlete");
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);
        }
    }

    private async Task Logout(long id)
    {
        try
        {
            var response = await Http.DeleteAsync($"api/Athlete/{id}");
            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add("Account disconnected successfully.", Severity.Success);
                await LoadAthletes();
            }
            else
            {
                Snackbar.Add("Error disconnecting account.", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error disconnecting account: {ex.Message}", Severity.Error);
        }
    }

    private async Task LoginWithStrava()
    {
        try
        {
            var redirectUri = $"{NavigationManager.BaseUri}strava-callback";
            var response = await Http.GetFromJsonAsync<AuthUrlResponse>($"api/Athlete/auth-url?redirectUri={redirectUri}");
            if (response != null)
            {
                NavigationManager.NavigateTo(response.Url);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error starting Strava OAuth: {ex.Message}", Severity.Error);
        }
    }

    private async Task SaveAthlete()
    {
        var response = await Http.PostAsJsonAsync("api/Athlete/setup-test", athlete);
        if (response.IsSuccessStatusCode)
        {
            Snackbar.Add("Athlete saved successfully! Syncing will start shortly.", Severity.Success);
            await LoadAthletes();
            athlete = new Athlete();
        }
        else
        {
            Snackbar.Add("Error saving athlete.", Severity.Error);
        }
    }

    private record AuthUrlResponse(string Url);
}
